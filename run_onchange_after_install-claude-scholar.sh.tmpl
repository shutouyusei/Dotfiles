#!/usr/bin/env bash
# Install Galaxy-Dawn/claude-scholar into ~/.claude on a fresh machine.
#
# This distributes claude-scholar's skills/commands/agents/rules/hooks/templates
# via the repo's own backup-aware setup.sh. The session hooks themselves are
# activated by dot_claude/settings.json.tmpl (canonical, tracked); the Zotero
# MCP block stays machine-local in ~/.claude/settings.json (it holds secrets and
# is intentionally not tracked, like model/effortLevel/tui).
#
# Re-runs whenever SCHOLAR_REF below changes (the ref is part of the script body,
# so chezmoi detects the change and re-executes). Bump it to update claude-scholar.
set -euo pipefail

SCHOLAR_REF="34d0cdb48a03080c7243841e19ff03ef30967d97"  # Galaxy-Dawn/claude-scholar
SCHOLAR_URL="https://github.com/Galaxy-Dawn/claude-scholar.git"
SCHOLAR_SRC="$HOME/.cache/claude-scholar"

{{ if eq .chezmoi.os "linux" -}}
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
{{ else if eq .chezmoi.os "darwin" -}}
if [ -x /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)"
fi
{{ end -}}

if ! command -v node >/dev/null 2>&1; then
  echo "claude-scholar: node not found in PATH, skipping (hooks need Node.js)" >&2
  exit 0
fi
if ! command -v git >/dev/null 2>&1; then
  echo "claude-scholar: git not found, skipping" >&2
  exit 0
fi

echo "--- claude-scholar: syncing $SCHOLAR_REF ---"
if [ ! -d "$SCHOLAR_SRC/.git" ]; then
  git clone --quiet "$SCHOLAR_URL" "$SCHOLAR_SRC"
fi
git -C "$SCHOLAR_SRC" fetch --quiet origin
git -C "$SCHOLAR_SRC" checkout --quiet "$SCHOLAR_REF"

echo "--- claude-scholar: running setup.sh ---"
bash "$SCHOLAR_SRC/scripts/setup.sh"

# Prune components we deliberately don't want. setup.sh installs everything, so
# this runs after it. Keep in sync with the curated removal set. Removed:
#   - SuperClaude /sc:* suite (redundant with superpowers)
#   - Web/UI skills (no web-app work; frontend-design duplicates the plugin)
#   - Dev-workflow dups (overlap superpowers + pr-review-toolkit/commit-commands/tdd-guard)
#   - Plugin-authoring meta-skills + Kaggle
#   - skill-forced-eval / session-summary / stop-summary hook scripts (dropped from settings)
echo "--- claude-scholar: pruning unwanted components ---"
CLAUDE_DIR="$HOME/.claude"
PRUNE=(
  commands/sc
  commands/commit.md commands/code-review.md commands/tdd.md commands/plan.md
  commands/verify.md commands/refactor-clean.md commands/build-fix.md commands/checkpoint.md
  skills/frontend-design skills/webapp-testing skills/web-design-reviewer skills/ui-ux-pro-max
  skills/bug-detective skills/daily-coding skills/git-workflow skills/code-review-excellence
  skills/planning-with-files skills/verification-loop
  skills/agent-identifier skills/command-development skills/hook-development skills/mcp-integration
  skills/plugin-structure skills/skill-development skills/skill-improver skills/skill-quality-reviewer
  skills/kaggle-learner
  agents/code-reviewer.md agents/tdd-guide.md agents/kaggle-miner.md
  hooks/skill-forced-eval.js hooks/session-summary.js hooks/stop-summary.js
)
for rel in "${PRUNE[@]}"; do
  rm -rf "$CLAUDE_DIR/$rel"
done
echo "claude-scholar: install + prune done"
